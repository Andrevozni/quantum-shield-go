{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "Node16",
    "moduleResolution":  "Node16",
    "lib":               ["ES2022", "DOM"],
    "outDir":            "../dist",
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "strict":            true,
    "esModuleInterop":   true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["."]
}
