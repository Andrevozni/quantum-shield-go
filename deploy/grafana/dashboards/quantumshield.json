{
  "id": null,
  "uid": "quantumshield-main",
  "title": "QuantumShield API",
  "description": "Post-quantum cryptographic platform — request rates, latency, crypto operations, and system health",
  "tags": ["quantumshield", "security", "pqc", "fips"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(qs_http_requests_total, job)",
        "refresh": 2,
        "includeAll": false,
        "current": {}
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "description": "Requests per second over the last 5 minutes (all endpoints)",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(qs_http_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (5xx)",
      "description": "Fraction of requests returning 5xx over the last 5 minutes",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(qs_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(qs_http_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "4xx Rate",
      "description": "Fraction of requests returning 4xx (client errors) over 5 minutes",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(qs_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(qs_http_requests_total[5m]))",
          "legendFormat": "4xx rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Uptime",
      "description": "Time since the process started",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "time() - qs_process_start_time_seconds",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Audit Log Entries",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "qs_audit_log_entries",
          "legendFormat": "entries",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Keystore Keys",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "qs_keystore_keys_total",
          "legendFormat": "keys",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "description": "Requests per second grouped by HTTP method and path",
      "gridPos": { "x": 0, "y": 6, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (method, path) (rate(qs_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "barchart",
      "title": "Top Endpoints (total requests)",
      "description": "Cumulative request count per endpoint since process start",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (path) (qs_http_requests_total))",
          "legendFormat": "{{path}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP Errors by Endpoint",
      "description": "5xx responses per second by path",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by (path, status) (rate(qs_http_requests_total{status=~\"[45]..\"}[5m]))",
          "legendFormat": "{{status}} {{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Status Code Distribution",
      "description": "Request rate split by HTTP status class",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(qs_http_requests_total{status=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(qs_http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(qs_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Latency",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Latency Percentiles (all endpoints)",
      "description": "p50 / p95 / p99 request latency across all endpoints",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "p95 Latency by Endpoint",
      "description": "95th-percentile latency per API path — useful for spotting slow endpoints (e.g. SLH-DSA-128s signing ≈ 20 ms)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 23,
      "type": "table",
      "title": "Latency Summary by Endpoint",
      "description": "p50 / p95 / p99 latency per path (snapshot over last 5 minutes)",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [{ "displayName": "p95", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (path, le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{path}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{path}}",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum by (path, le) (rate(qs_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{path}}",
          "refId": "C",
          "instant": true
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "Cryptographic Operations",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "Crypto Operations / sec",
      "description": "Rate of individual cryptographic operations — sign, verify, encrypt, decrypt, keygen, vault, tokens",
      "gridPos": { "x": 0, "y": 38, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        { "expr": "rate(qs_crypto_sign_total[5m])",                      "legendFormat": "sign (ML-DSA)",          "refId": "A" },
        { "expr": "rate(qs_crypto_verify_total[5m])",                     "legendFormat": "verify (ML-DSA/SLH)",   "refId": "B" },
        { "expr": "rate(qs_crypto_encrypt_total[5m])",                    "legendFormat": "encrypt (ML-KEM)",      "refId": "C" },
        { "expr": "rate(qs_crypto_decrypt_total[5m])",                    "legendFormat": "decrypt (ML-KEM)",      "refId": "D" },
        { "expr": "rate(qs_crypto_keygen_total[5m])",                     "legendFormat": "keygen",                "refId": "E" },
        { "expr": "rate(qs_crypto_vault_split_total[5m])",                "legendFormat": "vault split",           "refId": "F" },
        { "expr": "rate(qs_crypto_vault_reconstruct_total[5m])",          "legendFormat": "vault reconstruct",     "refId": "G" },
        { "expr": "rate(qs_crypto_token_issue_total[5m])",                "legendFormat": "token issue",           "refId": "H" },
        { "expr": "rate(qs_crypto_token_verify_total[5m])",               "legendFormat": "token verify",          "refId": "I" },
        { "expr": "rate(qs_crypto_channel_handshake_total[5m])",          "legendFormat": "channel handshake",     "refId": "J" },
        { "expr": "rate(qs_crypto_threshold_authorised_total[5m])",       "legendFormat": "threshold authorised",  "refId": "K" }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Crypto Errors / sec",
      "description": "Rate of cryptographic operation errors (decryption failures, checksum mismatches, invalid tokens, etc.)",
      "gridPos": { "x": 16, "y": 38, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(qs_crypto_errors_total[5m])",
          "legendFormat": "crypto errors",
          "refId": "A"
        }
      ]
    },

    {
      "id": 33,
      "type": "stat",
      "title": "Total Signs",
      "gridPos": { "x": 0, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "qs_crypto_sign_total", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Total Encryptions",
      "gridPos": { "x": 4, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "qs_crypto_encrypt_total", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 35,
      "type": "stat",
      "title": "Total Vault Splits",
      "gridPos": { "x": 8, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "qs_crypto_vault_split_total", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 36,
      "type": "stat",
      "title": "Total Tokens Issued",
      "gridPos": { "x": 12, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "qs_crypto_token_issue_total", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 37,
      "type": "stat",
      "title": "Threshold Authorisations",
      "gridPos": { "x": 16, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "qs_crypto_threshold_authorised_total", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 38,
      "type": "stat",
      "title": "Total Crypto Errors",
      "gridPos": { "x": 20, "y": 46, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [{ "expr": "qs_crypto_errors_total", "legendFormat": "", "refId": "A" }]
    }

  ]
}
